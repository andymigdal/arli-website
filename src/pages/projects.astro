---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Projects | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Projects</p>
				<h1>Real-world technology projects for rural properties and businesses.</h1>
				<p class="intro">
					Practical examples of automation, monitoring, connectivity and infrastructure work.
				</p>
			</section>

			<section class="project-grid">
				<h2>Farm Gate Automation</h2>
					<p>
					Retrofitted automation for an existing gate system including Bluetooth vehicle presence detection, automatic opening and Home Assistant integration.
					</p>
				<a href="/blog/farm-gate-automation">Read project →</a>
				</article>

				<article class="card">
					<h2>Bore Pump Flow Monitoring</h2>
					<p>Flow monitoring and alerts to help identify water issues before they become bigger problems.</p>
					<a href="/contact">Discuss similar work →</a>
				</article>

				<article class="card">
					<h2>Water Tank Dashboard</h2>
					<p>Tank level monitoring, usage tracking and smart alerts for rural water storage.</p>
					<a href="/contact">Discuss similar work →</a>
				</article>
			</section>
			
			<section class="future-projects">
	<h2>Future Project Notes</h2>
	<p>
		Upcoming articles and project notes currently being tested or planned.
	</p>

	<div class="project-grid">
		<article class="card">
			<h3>UniFi U7 Pro Outdoor Roof-Mounted Wi-Fi Testing</h3>
			<p>
				Real-world testing of a UniFi U7 Pro mounted high on a rural property roof,
				including range, throughput, coverage and device roaming observations.
			</p>
			<a href="/blog/unifi-u7-pro-roof-testing">Planned article →</a>
		</article>

		<article class="card">
			<h3>Water Tank Monitoring Dashboard</h3>
			<p>
				Tank level monitoring, usage trends and smart alerts for rural water storage.
			</p>
			<a href="/contact">Discuss similar work →</a>
		</article>

		<article class="card">
			<h3>Bore Pump Monitoring</h3>
			<p>
				Flow monitoring, alerts and automation to help identify water supply issues early.
			</p>
			<a href="/contact">Discuss similar work →</a>
		</article>
	</div>
</section>
			
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 2rem 0;
	}

	.eyebrow {
		color: var(--accent);
		font-weight: 750;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.85rem;
	}

	.intro {
		max-width: 800px;
		color: var(--muted);
		font-size: 1.2rem;
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
	}

	.card {
		background: var(--panel);
		border: 1px solid var(--border);
		border-top: 4px solid var(--accent);
		border-radius: 18px;
		padding: 1.5rem;
		box-shadow: var(--shadow);
	}

	.card h2 {
		font-size: 1.35rem;
	}

	.card a {
		font-weight: 700;
		text-decoration: none;
	}

	@media (max-width: 900px) {
		.project-grid {
			grid-template-columns: 1fr;
		}
	}
</style>