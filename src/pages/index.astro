---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Enterprise IT • Rural Technology • Automation</p>
				<h1>Technology solutions for businesses and rural properties.</h1>
				<p class="intro">
					From Microsoft 365 and business networks to Starlink, property Wi-Fi, automation and smart monitoring solutions.
				</p>
				<div class="actions">
					<a class="button primary" href="mailto:andy@arliconsulting.com.au">Get in touch</a>
					<a class="button secondary" href="/blog">Read the blog</a>
				</div>
			</section>

			<section class="cards">
				<article>
					<h2>Business IT</h2>
					<p>Microsoft 365, cloud services, backups, security, networking and reliable support for small businesses.</p>
				</article>

				<article>
					<h2>Enterprise Infrastructure</h2>
					<p>Nutanix, VMware, Microsoft 365, backup and recovery, storage platforms and infrastructure consulting.</p>
				</article>

				<article>
					<h2>Rural Technology</h2>
					<p>Starlink, acreage Wi-Fi, cameras, gate automation, water tank monitoring and practical smart property systems.</p>
				</article>
			</section>

			<section class="feature">
				<h2>Recent project notes</h2>
				<p>
					The blog will cover real-world projects including Home Assistant gate automation,
					bore pump flow monitoring, tank level dashboards and technology that makes rural
					properties easier to manage.
				</p>
				<a href="/blog">View blog articles →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		padding: 2rem 0 2rem;
		max-width: 1100px;
	}

	.eyebrow {
		color: var(--accent);
		font-weight: 750;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		font-size: 0.85rem;
		margin-bottom: 1rem;
	}

	.hero h1 {
		max-width: 1000px;
		font-size: clamp(2.2rem, 5vw, 3.8rem);
		line-height: 1.02;
		margin-bottom: 1.4rem;
	}

	.intro {
		max-width: 900px;
		font-size: 1.25rem;
		color: var(--muted);
	}

	.actions {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
		margin-top: 2rem;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.85rem 1.2rem;
		border-radius: 999px;
		font-weight: 700;
		text-decoration: none;
	}

	.button.primary {
		background: var(--accent);
		color: white;
	}

	.button.secondary {
		background: white;
		color: var(--accent);
		border: 1px solid var(--border);
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 1rem;
		margin: 2rem 0 3rem;
	}

	.cards article,
	.feature {
		background: var(--panel);
		border: 1px solid var(--border);
		border-radius: 18px;
		padding: 1.5rem;
		box-shadow: var(--shadow);
	}

	.cards article {
		border-top: 4px solid var(--accent);
	}

	.cards h2 {
		font-size: 1.35rem;
	}

	.feature {
		margin-bottom: 2rem;
	}

	@media (max-width: 820px) {
		.cards {
			grid-template-columns: 1fr;
		}
	}
</style>